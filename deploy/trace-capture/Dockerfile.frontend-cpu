# CPU-only vLLM frontend image for the agentic capture / offline replay rigs.
#
# The API-server-only node (`vllm serve --data-parallel-size-local 0`) does no
# inference, but vLLM's platform probe still needs a resolvable device: the
# CUDA CI image crashes with "Failed to infer device type" on a GPU-less
# container, and an `empty`-target build resolves to UnspecifiedPlatform and
# crashes the same way. The CPU wheel's version string (`...+gc9340e6f3.cpu`)
# is what activates CpuPlatform, so we install the upstream per-commit CPU
# wheel for EXACTLY the protocol-pin commit (c9340e6f3, see Cargo.toml) -- no
# source build, no protocol skew with the engine/sim.
#
#   podman build --platform linux/amd64 \
#     -f deploy/trace-capture/Dockerfile.frontend-cpu \
#     -t quay.io/wseaton/mock-engine-nixl:vllm-frontend-cpu-c9340e6f3 .
FROM python:3.12-slim

ARG VLLM_COMMIT=c9340e6f350a009cf835878abad2a0e379b9e6a4
# The exact wheel version string at ${VLLM_COMMIT}'s CPU index (it embeds the
# short sha, so it MUST move with VLLM_COMMIT). Find it at
# https://wheels.vllm.ai/${VLLM_COMMIT}/cpu/vllm/ . Default = the c9340e6f pin.
ARG VLLM_VERSION=0.22.1rc1.dev431+gc9340e6f3.cpu

# numactl: CpuPlatform probes it at import; curl for debugging.
RUN apt-get update && apt-get install -y --no-install-recommends \
        numactl curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# The per-commit CPU wheel index carries vllm itself; torch/cpu and the rest
# resolve from the pytorch CPU index + pypi.
RUN uv pip install --system \
        --extra-index-url https://wheels.vllm.ai/${VLLM_COMMIT}/cpu/ \
        --extra-index-url https://download.pytorch.org/whl/cpu \
        --index-strategy unsafe-best-match \
        "vllm==${VLLM_VERSION}"

ENTRYPOINT ["vllm"]
